{
  "name": "chidori-fetch",
  "version": "0.1.9",
  "description": "Fast Rust-built web-to-Markdown fetcher for AI agents",
  "homepage": "https://github.com/taishikato/chidori#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taishikato/chidori.git"
  },
  "bugs": {
    "url": "https://github.com/taishikato/chidori/issues"
  },
  "bin": {
    "chidori": "bin/chidori.js"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "cargo build --release",
    "clean": "cargo clean",
    "format": "cargo fmt --all",
    "format:check": "cargo fmt --all -- --check",
    "lint": "cargo clippy --all-targets --all-features -- -D warnings",
    "parity:local": "node tools/parity-harness.mjs",
    "parity:json": "node tools/parity-harness.mjs --json",
    "precommit": "npm run format:check && npm run lint",
    "test": "cargo test",
    "test:tools": "node --test tools/*.test.mjs"
  },
  "optionalDependencies": {
    "@chidori-fetch/darwin-arm64": "0.1.9",
    "@chidori-fetch/darwin-x64": "0.1.9",
    "@chidori-fetch/linux-arm64": "0.1.9",
    "@chidori-fetch/linux-x64": "0.1.9",
    "@chidori-fetch/win32-arm64": "0.1.9",
    "@chidori-fetch/win32-x64": "0.1.9"
  },
  "keywords": [
    "markdown",
    "rust",
    "cli",
    "agent",
    "web",
    "fetch"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6"
}

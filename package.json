{
  "name": "chidori-fetch",
  "version": "0.1.5",
  "description": "Fast Rust-built web-to-Markdown fetcher for AI agents",
  "homepage": "https://github.com/taishikato/chidori#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taishikato/chidori.git"
  },
  "bugs": {
    "url": "https://github.com/taishikato/chidori/issues"
  },
  "bin": {
    "chidori": "bin/chidori.js"
  },
  "files": [
    "bin",
    "src",
    "Cargo.toml",
    "Cargo.lock",
    "README.md"
  ],
  "scripts": {
    "build": "cargo build --release",
    "format": "cargo fmt --all",
    "format:check": "cargo fmt --all -- --check",
    "lint": "cargo clippy --all-targets --all-features -- -D warnings",
    "parity:local": "node tools/parity-harness.mjs",
    "precommit": "npm run format:check && npm run lint",
    "test": "cargo test",
    "install": "cargo build --release",
    "prepack": "npm run build"
  },
  "keywords": [
    "markdown",
    "rust",
    "cli",
    "agent",
    "web",
    "fetch"
  ],
  "license": "MIT"
}
